#!groovy
import groovy.json.JsonOutput
import org.folio.Constants
import org.folio.jenkins.PodTemplates
import org.jenkinsci.plugins.workflow.libs.Library

@Library('pipelines-shared-library') _

properties([
  buildDiscarder(logRotator(numToKeepStr: '20')),
  disableConcurrentBuilds(),
  parameters([
    folioParameters.cluster(),
    folioParameters.namespace(),
    string(name: 'BACKUP_NAME', defaultValue: '', description: '(Optional) Custom backup name. If empty, auto-generated as CLUSTER-NAMESPACE-BUILD_ID'),
    choice(name: 'BACKUP_SCOPE', choices: ['full', 'db-only'], description: 'full = DB dump + tenant/entitlements JSON metadata; db-only = PostgreSQL dump only'),
    string(name: 'TIMEOUT', defaultValue: '360m', description: 'Helm install timeout (e.g. 360m, 6h, 90m)'),
    string(name: 'PVC_SIZE', defaultValue: '100Gi', description: 'PVC storage size for the dump volume (e.g. 100Gi, 500Gi)'),
    folioParameters.refreshParameters()
  ])
])

if (params.REFRESH_PARAMETERS) {
  currentBuild.result = 'ABORTED'
  return
}

PodTemplates podTemplates = new PodTemplates(this)
String bucketName = Constants.PSQL_DUMP_BACKUPS_BUCKET_NAME
String helmRepoName = Constants.FOLIO_HELM_HOSTED_REPO_NAME
String helmRepoUrl = Constants.FOLIO_HELM_HOSTED_REPO_URL
String chartName = Constants.PSQL_DUMP_HELM_CHART_NAME
String chartVersion = Constants.PSQL_DUMP_HELM_INSTALL_CHART_VERSION
String backupName = params.BACKUP_NAME ?: "${params.CLUSTER}-${params.NAMESPACE}-${env.BUILD_ID}"
String s3Directory = "${params.CLUSTER}/${params.NAMESPACE}"

ansiColor('xterm') {
  podTemplates.rancherAgent {
    stage('Ini') {
      buildName("#${backupName}")
      buildDescription("backup: ${params.CLUSTER}/${params.NAMESPACE} [${params.BACKUP_SCOPE}]")
    }

    stage('Checkout') {
      checkout(poll: false,
        scm: scmGit(branches: [[name: "*/${folioTools.getPipelineBranch()}"]],
          extensions: [cloneOption(depth: 50, noTags: true, reference: '', shallow: true)],
          userRemoteConfigs: [[credentialsId: Constants.PRIVATE_GITHUB_CREDENTIALS_ID,
                               url          : "${Constants.FOLIO_GITHUB_URL}/pipelines-shared-library.git"]]))
    }

    stage('Configure kubectl') {
      psqlDumpMethods.configureKubectl(Constants.AWS_REGION, params.CLUSTER)
    }

    stage('Configure Helm') {
      psqlDumpMethods.configureHelm(helmRepoName, helmRepoUrl)
    }

    // Collect tenant/entitlements metadata for Eureka clusters when scope=full
    if (params.BACKUP_SCOPE == 'full') {
      stage('Fetch tenants from Kong') {
        awscli.withAwsClient {
          String kongUrl = psqlDumpMethods.getKongUrl(params.CLUSTER, params.NAMESPACE)
          def tenantsJson = psqlDumpMethods.fetchTenants(kongUrl)
          List tenants = tenantsJson.tenants ?: []

          echo "Found ${tenants.size()} tenants in ${params.CLUSTER}/${params.NAMESPACE}"

          // Save tenants list as JSON to S3
          psqlDumpMethods.saveTenantsMetadataToS3(
            bucketName, s3Directory, backupName,
            JsonOutput.toJson(tenantsJson)
          )

          // Fetch entitlements for all tenants and save to S3
          psqlDumpMethods.saveEntitlementsMetadataToS3(
            bucketName, s3Directory, backupName,
            kongUrl, tenants
          )
        }
      }
    }

    stage('Resolve DB credentials') {
      awscli.withAwsClient {
        Map dbCreds = psqlDumpMethods.getDBCredentials(params.NAMESPACE)
        echo "Using DB: ${dbCreds.host}:${dbCreds.port}/${dbCreds.db} as ${dbCreds.user}"
        env.PSQL_CONNECTION_URI = psqlDumpMethods.buildPsqlConnectionUri(dbCreds)
      }
    }

    stage('Helm install') {
      try {
        awscli.withAwsClient {
          psqlDumpMethods.backupHelmInstall(
            env.BUILD_ID, helmRepoName, chartName, chartVersion,
            params.NAMESPACE, params.CLUSTER, backupName,
            bucketName, s3Directory, params.TIMEOUT, params.PVC_SIZE
          )
        }
      } catch (Exception err) {
        echo "Helm install failed: ${err.getMessage()}"
        currentBuild.result = 'FAILURE'
        error("Backup failed, see logs above")
      } finally {
        stage('Cleanup Helm release') {
          sh "helm delete psql-dump-build-id-${env.BUILD_ID} --namespace=${params.NAMESPACE} 2>/dev/null || echo 'Helm release already cleaned up'"
        }
      }
    }

    stage('Finalize') {
      echo "Backup ${backupName} finished for ${params.CLUSTER}/${params.NAMESPACE}"
      buildDescription("backup done: ${backupName}")
    }
  }
}
