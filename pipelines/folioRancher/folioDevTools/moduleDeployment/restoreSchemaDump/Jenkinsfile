#!groovy

import org.folio.jenkins.PodTemplates
import org.folio.utilities.Logger
import org.jenkinsci.plugins.workflow.libs.Library

@Library('pipelines-shared-library@db_dump_restore') _

properties([
  buildDiscarder(logRotator(numToKeepStr: '30')),
  disableConcurrentBuilds(),
  parameters([
    folioParameters.cluster(),
    folioParameters.namespace(),
    stashedFile(name: 'SCHEMA_DUMP', description: 'DB dump to restore'),
      folioParameters.refreshParameters()
  ])
])

if (params.REFRESH_PARAMETERS) {
  currentBuild.result = 'ABORTED'
  return
}

if (params.CLUSTER == 'folio-etesting') {
  folioCommon.kitfoxApproval()
}

PodTemplates podTemplates = new PodTemplates(this)
Logger logger = new Logger(this, env.JOB_BASE_NAME)

ansiColor('xterm') {
  podTemplates.rancherAgent {
    try {
      stage('Ini') {
        buildName('Restore schema dump: ' + $SCHEMA_DUMP_FILENAME)
        buildDescription('Target environment: ' + params.CLUSTER + '-' + params.NAMESPACE)
      }
      stage('Checkout') {
        checkout scm
      }
      stage('[isRunning]') {
        folioHelm.withKubeConfig(params.CLUSTER) {
          def check = sh(script: "kubectl get pods --namespace ${params.NAMESPACE} --no-headers", returnStdout: true).trim()
          if (!check.contains('postgres')) {
            logger.error("Reason: target env is not running or postgreSQL is not presented in environment")
          }
        }
      }
      stage('Prepare') {
        logger.info("Preparing to restore schema dump to environment: ${params.CLUSTER}-${params.NAMESPACE}")
        unstash 'SCHEMA_DUMP'
        sh "du -sh $SCHEMA_DUMP_FILENAME"
      }
    } catch (e) {
      logger.warning("Caught exception: ${e}")
      error(e.getMessage())
    }
  }
}
