#!groovy
import org.folio.jenkins.PodTemplates
import org.folio.utilities.Logger
import org.jenkinsci.plugins.workflow.libs.Library

@Library('pipelines-shared-library@MDEXP-908') _

properties([
  buildDiscarder(logRotator(numToKeepStr: '30')),
  disableConcurrentBuilds(),
  parameters([
    folioParameters.cluster(),
    folioParameters.namespace(),
    string(name: 'MODULE', defaultValue: '', description: '(Required) Short module name, e.g. mod-fqm-manager'),
    string(name: 'TENANT', defaultValue: '', description: '(Required) Tenant name to reinstall module on'),
    folioParameters.refreshParameters()
  ])
])

if (params.REFRESH_PARAMETERS) {
  currentBuild.result = 'ABORTED'
  return
}

PodTemplates podTemplates = new PodTemplates(this)
Logger logger = new Logger(this, env.JOB_BASE_NAME)

ansiColor('xterm') {
  podTemplates.rancherAgent {
    stage('Ini') {
      buildName "Reinstall ${params.MODULE} on ${params.TENANT}"
      buildDescription "${params.CLUSTER}-${params.NAMESPACE}"
    }

    stage('Checkout') {
      checkout scm
    }

    stage('[FIX] Reinstall module via Kong') {
      logger.info("Reinstalling module: ${params.MODULE} on tenant: ${params.TENANT}")

      String kongBase = "https://${params.CLUSTER}-${params.NAMESPACE}.kong.ci.folio.org"

      String tenantsResponse = sh(
        script: "curl -sf '${kongBase}/tenants?limit=500'",
        returnStdout: true
      ).trim()
      def tenantsPayload = readJSON text: tenantsResponse
      def tenantObj = tenantsPayload.tenants.find { it.name == params.TENANT }
      if (!tenantObj) {
        error("Tenant '${params.TENANT}' not found")
      }
      String tenantId = tenantObj.id

      String appsResponse = sh(
        script: "curl -sf '${kongBase}/applications?limit=500'",
        returnStdout: true
      ).trim()
      def appsPayload = readJSON text: appsResponse
      String moduleId = null
      String applicationId = null
      for (app in appsPayload.applicationDescriptors) {
        def moduleObj = app.modules?.find { it.name == params.MODULE }
        if (moduleObj) {
          moduleId = moduleObj.id
          applicationId = app.id
          break
        }
      }
      if (!moduleId) {
        error("Module '${params.MODULE}' not found in any application")
      }
      logger.info("Resolved moduleId=${moduleId}, applicationId=${applicationId}, tenantId=${tenantId}")

      String body = groovy.json.JsonOutput.toJson([
        tenantId     : tenantId,
        applicationId: applicationId,
        modules      : [moduleId]
      ])

      sh "curl -sf -X POST -H 'Content-Type: application/json' -d '${body}' '${kongBase}/reinstall/modules'"

      logger.info("Module ${moduleId} reinstalled successfully on tenant ${params.TENANT}")
    }
  }
}
