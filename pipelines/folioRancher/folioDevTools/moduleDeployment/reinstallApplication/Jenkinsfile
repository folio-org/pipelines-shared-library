#!groovy
import org.folio.jenkins.PodTemplates
import org.folio.utilities.Logger
import org.jenkinsci.plugins.workflow.libs.Library

@Library('pipelines-shared-library') _

properties([
  buildDiscarder(logRotator(numToKeepStr: '30')),
  disableConcurrentBuilds(),
  parameters([
    folioParameters.cluster(),
    folioParameters.namespace(),
    string(name: 'APPLICATIONS', defaultValue: '', description: '(Required) Comma-separated list of short app names, e.g. app-fqm,app-inventory'),
    string(name: 'TENANT', defaultValue: '', description: '(Required) Tenant name to reinstall applications on'),
    folioParameters.loadReference(),
    folioParameters.loadSample(),
    folioParameters.refreshParameters()
  ])
])

if (params.REFRESH_PARAMETERS) {
  currentBuild.result = 'ABORTED'
  return
}

PodTemplates podTemplates = new PodTemplates(this)
Logger logger = new Logger(this, env.JOB_BASE_NAME)

ansiColor('xterm') {
  podTemplates.rancherAgent {
    stage('Ini') {
      buildName "Reinstall ${params.APPLICATIONS} on ${params.TENANT}"
      buildDescription "${params.CLUSTER}-${params.NAMESPACE}"
    }

    stage('Checkout') {
      checkout scm
    }

    stage('[FIX] Reinstall applications via Kong') {
      logger.info("Reinstalling applications: ${params.APPLICATIONS} on tenant: ${params.TENANT}")

      String kongBase = "https://${params.CLUSTER}-${params.NAMESPACE}-kong.ci.folio.org"

      String tenantsResponse = sh(
        script: "curl -sf '${kongBase}/tenants?limit=500'",
        returnStdout: true
      ).trim()
      def tenantsPayload = readJSON text: tenantsResponse
      def tenantObj = tenantsPayload.tenants.find { it.name == params.TENANT }
      if (!tenantObj) {
        error("Tenant '${params.TENANT}' not found")
      }
      String tenantId = tenantObj.id

      String appsResponse = sh(
        script: "curl -sf '${kongBase}/applications?limit=500'",
        returnStdout: true
      ).trim()
      def appsPayload = readJSON text: appsResponse

      List<String> requestedApps = params.APPLICATIONS.split(',').collect { it.trim() }
      List<String> resolvedAppIds = []
      requestedApps.each { appName ->
        def appObj = appsPayload.applicationDescriptors.find { it.name == appName }
        if (!appObj) {
          error("Application '${appName}' not found in Kong")
        }
        resolvedAppIds << appObj.id
      }
      logger.info("Resolved applicationIds=${resolvedAppIds}, tenantId=${tenantId}")

      String keycloakBase = "https://${params.CLUSTER}-${params.NAMESPACE}-keycloak.ci.folio.org"
      String tokenResponse = sh(
        script: "curl -sf -X POST '${keycloakBase}/realms/master/protocol/openid-connect/token' -H 'Content-Type: application/x-www-form-urlencoded' -d 'client_id=folio-backend-admin-client&client_secret=SecretPassword&grant_type=client_credentials'",
        returnStdout: true
      ).trim()
      def tokenPayload = readJSON text: tokenResponse
      String accessToken = tokenPayload.access_token

      String body = groovy.json.JsonOutput.toJson([
        tenantId    : tenantId,
        applications: resolvedAppIds
      ])

      sh "curl -sf -X POST -H 'Content-Type: application/json' -H 'x-okapi-token: ${accessToken}' -d '${body}' '${kongBase}/reinstall/applications?tenantParameters=loadReference=${params.LOAD_REFERENCE},loadSample=${params.LOAD_SAMPLE}'"

      logger.info("Applications ${resolvedAppIds} reinstalled successfully on tenant ${params.TENANT}")
    }
  }
}
